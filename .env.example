# Copy this file to .env.local and fill in your values.
# NEVER put real keys in this file — it is committed to git. Real secrets go in
# .env.local (which is gitignored).

# Public site URL for password-reset / confirm email links (match Supabase Site URL).
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Supabase Auth — PUBLIC keys (safe in the browser). Required for login/signup.
# Get these from Supabase → Project Settings → API (URL + anon/publishable key).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_publishable_key

# --- OpenRouter (text generation) ---
# One key, many models. Get it at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key
# Defaults; override per task with MODEL_* vars. IDs: https://openrouter.ai/models
OPENROUTER_MODEL=openai/gpt-4o
OPENROUTER_MODEL_CHEAP=openai/gpt-4o-mini
# Image model for the "Generate AI image" button:
MODEL_IMAGE=google/gemini-3-pro-image
# Optional per-task overrides:
# MODEL_WRITER=anthropic/claude-sonnet-4.6
# MODEL_HOOK=anthropic/claude-sonnet-4.6
# MODEL_TOPIC=openai/gpt-4o
# MODEL_SCORING=openai/gpt-4o-mini
# MODEL_HASHTAG=openai/gpt-4o-mini
# MODEL_VISUAL=openai/gpt-4o-mini
# MODEL_CALENDAR=openai/gpt-4o-mini

# --- Gemini (embeddings ONLY) ---
# Used just for the RAG vector store now. Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# --- Supabase (OPTIONAL) ---
# Leave blank to use the local disk/localStorage stores (zero setup).
# Set both to move brand memory to Postgres + pgvector (required for serverless
# persistence). See SUPABASE_SETUP.md.
# IMPORTANT: use the SECRET key (sb_secret_...), not the publishable key — the
# server needs to bypass row-level security. Never expose the secret key to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_secret_key
