# Copy this file to .env.local and fill in your values.
# NEVER put real keys in this file — it is committed to git. Real secrets go in
# .env.local (which is gitignored).

# Password that gates the whole app (login screen). REQUIRED in production —
# if unset, the deployed site stays locked. Use a long, random value.
APP_PASSWORD=choose_a_long_random_password

# Get a free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Default model. gemini-2.5-flash-lite has a generous free-tier quota
# (~1,500 req/day); gemini-2.5-flash is higher quality but ~20 req/day on free tier.
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Supabase (OPTIONAL) ---
# Leave blank to use the local disk/localStorage stores (zero setup).
# Set both to move brand memory to Postgres + pgvector (required for serverless
# persistence). See SUPABASE_SETUP.md.
# IMPORTANT: use the SECRET key (sb_secret_...), not the publishable key — the
# server needs to bypass row-level security. Never expose the secret key to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_secret_key
